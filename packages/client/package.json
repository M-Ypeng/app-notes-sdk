{
  "name": "@company/app-notes-client",
  "version": "0.1.0",
  "description": "App Notes Web Components client SDK",
  "type": "module",
  "main": "./dist/app-notes-sdk.js",
  "module": "./dist/app-notes-sdk.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/app-notes-sdk.esm.js",
      "require": "./dist/app-notes-sdk.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c ../../rollup.config.js && rollup -c rollup.esm.config.js",
    "dev": "rollup -c ../../rollup.config.js -w"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "rollup": "^4.35.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2"
  }
}
